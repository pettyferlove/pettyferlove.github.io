        <category>DevOps</category>
        <category>APM</category>
      </categories>
      <tags>
        <tag>云原生基础设施</tag>
        <tag>运维</tag>
        <tag>链路追踪</tag>
        <tag>性能监控</tag>
        <tag>预警</tag>
      </tags>
